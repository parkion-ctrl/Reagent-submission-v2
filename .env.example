# 이 파일을 복사해서 .env로 만들고 실제 값을 채워 넣으세요.
# .env는 git에 올라가지 않습니다 (.gitignore에 포함됨).

REAGENT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_LONG_STRING
REAGENT_PGDATABASE=reagent
REAGENT_PGUSER=postgres
REAGENT_PGPASSWORD=CHANGE_ME
REAGENT_PGHOST=localhost
REAGENT_PGPORT=5432

# 로컬 개발 중 디버그 화면이 필요하면 아래를 True로 바꾸세요.
# (실사용 서버(run_server.py)에서는 절대 True로 두지 마세요)
REAGENT_DEBUG=False
